{
    "name": "yassinds22/repository-service",
    "description": "A Laravel package that automatically creates repositories and services folders and provides command generators.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Yassin",
            "email": "yassin@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Custom\\RepositoryService\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Custom\\RepositoryService\\RepositoryServiceServiceProvider"
            ]
        }
    }
}
